---
import BaseLayout from '../layouts/BaseLayout.astro';
import gpuData from '../data/gpu_ai_perf.json';

// 提取所有不重复的厂商、架构与定位分类
const vendors = [...new Set(gpuData.map(item => item.vendor))].sort();
const allArchitectures = [...new Set(gpuData.map(item => item.architecture))].sort();
const allSegments = [...new Set(gpuData.map(item => item.segment))].sort();
---

<BaseLayout title="开发者小工具箱" description="提供硬件底层的 DDR 带宽计算器、汇编 Cheatsheet 等实用开发者工具。">
	<div class="tools-layout">
		<!-- 侧边导航栏 -->
		<aside class="tools-sidebar">
			<div class="glass-card sidebar-card">
				<h3 class="sidebar-title">工具箱</h3>
				<nav class="sidebar-nav">
					<button class="nav-item active" data-tool="ddr-calc">
						<span class="nav-icon">📊</span>
						<span class="nav-label">DDR 带宽计算器</span>
					</button>
					<button class="nav-item" data-tool="asm-sheet">
						<span class="nav-icon">💻</span>
						<span class="nav-label">汇编 Cheatsheet</span>
					</button>
					<button class="nav-item" data-tool="gpu-ai-perf">
						<span class="nav-icon">⚡</span>
						<span class="nav-label">显卡 AI 算力对照</span>
					</button>
				</nav>
			</div>
		</aside>

		<!-- 主内容区域 -->
		<main class="tools-main">
			<!-- 工具 A: DDR 带宽计算器 -->
			<section id="tool-ddr-calc" class="tool-section active">
				<div class="glass-card">
					<div class="tool-header">
						<h2>📊 DDR 带宽计算器</h2>
						<p class="tool-desc">输入内存等效数据速率、单通道位宽及通道数量，实时评估硬件的数据传输速率与理论最大吞吐带宽。</p>
					</div>

					<div class="calc-grid">
						<!-- 左侧输入面板 -->
						<div class="calc-inputs">
							<!-- 预设规格 -->
							<div class="form-group">
								<label for="ddr-preset">常用规格预设</label>
								<select id="ddr-preset" class="form-control">
									<option value="">-- 自定义参数 --</option>
									<option value="ddr4-3200-single" data-rate="3200" data-width="64" data-channels="1">DDR4-3200 单通道 (桌面 PC)</option>
									<option value="ddr4-3200-dual" data-rate="3200" data-width="64" data-channels="2" selected>DDR4-3200 双通道 (传统主流 PC)</option>
									<option value="ddr5-5600-dual" data-rate="5600" data-width="32" data-channels="4">DDR5-5600 双通道 (等效 4x32-bit 子通道)</option>
									<option value="lpddr5-6400-quad" data-rate="6400" data-width="16" data-channels="4">LPDDR5-6400 四通道 (超薄本/旗舰移动 SoC)</option>
									<option value="lpddr5x-8533-quad" data-rate="8533" data-width="16" data-channels="4">LPDDR5X-8533 四通道 (苹果 M系/旗舰天玑 9300)</option>
									<option value="gddr6-a770" data-rate="16000" data-width="32" data-channels="8">GDDR6 16Gbps (显卡 A770 256-bit 位宽)</option>
									<option value="hbm2e-ps5" data-rate="3200" data-width="1024" data-channels="4">HBM2e 4-Stack (超宽总线 HPC 加速卡)</option>
								</select>
							</div>

							<!-- 等效频率 -->
							<div class="form-group">
								<label for="ddr-rate">等效数据速率 (MT/s)</label>
								<div class="input-with-unit">
									<input type="number" id="ddr-rate" class="form-control" value="3200" min="1" max="100000" />
									<span class="unit">MT/s</span>
								</div>
							</div>

							<!-- 通道位宽 -->
							<div class="form-group">
								<label for="ddr-width">单通道物理位宽 (Bit Width)</label>
								<select id="ddr-width" class="form-control">
									<option value="8">8-bit</option>
									<option value="16">16-bit (LPDDR5 单子通道)</option>
									<option value="32">32-bit (LPDDR4x/GDDR6 单通道)</option>
									<option value="64" selected>64-bit (标准 DDR3/DDR4 单通道)</option>
									<option value="128">128-bit</option>
									<option value="1024">1024-bit (HBM 单 Stack 位宽)</option>
								</select>
							</div>

							<!-- 通道数 -->
							<div class="form-group">
								<label for="ddr-channels">内存通道数 (Channels)</label>
								<div class="input-with-unit">
									<input type="number" id="ddr-channels" class="form-control" value="2" min="1" max="32" />
									<span class="unit">通道</span>
								</div>
							</div>
						</div>

						<!-- 右侧计算结果面板 -->
						<div class="calc-results">
							<div class="result-card">
								<div class="result-label">理论吞吐带宽 (GB/s)</div>
								<div class="result-value" id="bandwidth-gb">51.20</div>
								<div class="result-sub-value" id="bandwidth-mb">51,200 MB/s</div>
							</div>

							<div class="result-details">
								<div class="detail-row">
									<span class="detail-label">等效总位宽</span>
									<span class="detail-val" id="total-width">128-bit</span>
								</div>
								<div class="detail-row">
									<span class="detail-label">时钟时序频率</span>
									<span class="detail-val" id="clock-freq">1600.0 MHz</span>
								</div>
								<div class="formula-box">
									<div class="formula-title">计算公式过程：</div>
									<div class="formula-text" id="calc-formula">
										带宽 = 3200 MT/s × 64-bit × 2 通道 ÷ 8 bits/Byte ÷ 1000 = 51.20 GB/s
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- 工具 B: 汇编 Cheatsheet -->
			<section id="tool-asm-sheet" class="tool-section">
				<div class="glass-card">
					<div class="tool-header">
						<h2>💻 汇编 Cheatsheet</h2>
						<p class="tool-desc">对比 x86_64 与 ARM64 (AArch64) 架构的核心寄存器布局、函数参数调用约定，以及高频机器指令的映射和对比速查。</p>
					</div>

					<!-- 架构子切换 Tab -->
					<div class="tab-container">
						<button class="tab-btn active" data-arch="register-compare">通用寄存器对比</button>
						<button class="tab-btn" data-arch="inst-data">数据与算术指令</button>
						<button class="tab-btn" data-arch="inst-control">分支与控制指令</button>
					</div>

					<!-- 子 Tab 1: 通用寄存器对比 -->
					<div id="arch-register-compare" class="tab-panel active">
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>寄存器功能角色</th>
										<th>x86_64 寄存器</th>
										<th>ARM64 (AArch64) 寄存器</th>
										<th>特性及调用约定 (ABI) 说明</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td><strong>累加 / 第一返回值</strong></td>
										<td><code>rax</code></td>
										<td><code>x0</code></td>
										<td>保存函数首个整型返回值。在 x86 中是隐含的累加操作器。</td>
									</tr>
									<tr>
										<td><strong>第二返回值</strong></td>
										<td><code>rdx</code></td>
										<td><code>x1</code></td>
										<td>保存函数第二个整型返回值；x86 中也用于 128位 乘除的高位。</td>
									</tr>
									<tr>
										<td><strong>函数实参 1</strong></td>
										<td><code>rdi</code></td>
										<td><code>x0</code></td>
										<td>函数调用传递的第 1 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>函数实参 2</strong></td>
										<td><code>rsi</code></td>
										<td><code>x1</code></td>
										<td>函数调用传递的第 2 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>函数实参 3</strong></td>
										<td><code>rdx</code></td>
										<td><code>x2</code></td>
										<td>函数调用传递的第 3 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>函数实参 4</strong></td>
										<td><code>rcx</code></td>
										<td><code>x3</code></td>
										<td>函数调用传递的第 4 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>函数实参 5</strong></td>
										<td><code>r8</code></td>
										<td><code>x4</code></td>
										<td>函数调用传递的第 5 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>函数实参 6</strong></td>
										<td><code>r9</code></td>
										<td><code>x5</code></td>
										<td>函数调用传递 of 第 6 个整型/指针参数。</td>
									</tr>
									<tr>
										<td><strong>额外函数参数</strong></td>
										<td>通过堆栈传递</td>
										<td><code>x6</code> - <code>x7</code></td>
										<td>ARM64 有 8 个传参寄存器；x86_64 仅 6 个，超出部分借由堆栈。</td>
									</tr>
									<tr>
										<td><strong>临时寄存器</strong></td>
										<td><code>r10</code>, <code>r11</code></td>
										<td><code>x9</code> - <code>x15</code></td>
										<td><strong>Caller-saved</strong>。调用者保护。子函数可以随意覆写。</td>
									</tr>
									<tr>
										<td><strong>静态寄存器</strong></td>
										<td><code>rbx</code>, <code>r12</code> - <code>r15</code></td>
										<td><code>x19</code> - <code>x28</code></td>
										<td><strong>Callee-saved</strong>。被调用者保护。子函数改动前须入栈保护并复原。</td>
									</tr>
									<tr>
										<td><strong>帧指针 (FP)</strong></td>
										<td><code>rbp</code></td>
										<td><code>x29</code> (<code>fp</code>)</td>
										<td>指向当前栈帧底部，辅助编译器定位局部变量和传参。</td>
									</tr>
									<tr>
										<td><strong>链接寄存器 (LR)</strong></td>
										<td>通过堆栈传递</td>
										<td><code>x30</code> (<code>lr</code>)</td>
										<td>保存当前函数返回地址。ARM 硬件级提速机制；x86 通过压栈保存。</td>
									</tr>
									<tr>
										<td><strong>栈指针 (SP)</strong></td>
										<td><code>rsp</code></td>
										<td><code>sp</code></td>
										<td>指向当前栈帧顶部。</td>
									</tr>
									<tr>
										<td><strong>指令指针 (PC)</strong></td>
										<td><code>rip</code></td>
										<td><code>pc</code></td>
										<td>指向下一条即将执行的二进制机器指令。</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

					<!-- 子 Tab 2: 数据与算术指令 -->
					<div id="arch-inst-data" class="tab-panel">
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>操作类型</th>
										<th>x86_64 指令</th>
										<th>ARM64 指令</th>
										<th>功能与差异示例说明</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td><strong>数据传送</strong></td>
										<td><code>mov rax, rbx</code></td>
										<td><code>mov x0, x1</code></td>
										<td>通用数据寄存器拷贝。x86 是 <code>mov dst, src</code>。</td>
									</tr>
									<tr>
										<td><strong>内存加载</strong></td>
										<td><code>mov rax, [rbx]</code></td>
										<td><code>ldr x0, [x1]</code></td>
										<td>从内存地址（寄存器指针值）加载数据到寄存器。</td>
									</tr>
									<tr>
										<td><strong>内存存储</strong></td>
										<td><code>mov [rax], rbx</code></td>
										<td><code>str x1, [x0]</code></td>
										<td>将寄存器内容存回指定的内存地址。</td>
									</tr>
									<tr>
										<td><strong>对入栈出栈</strong></td>
										<td>不支持</td>
										<td><code>stp x0, x1, [sp, #-16]!</code><br/><code>ldp x0, x1, [sp], #16</code></td>
										<td>ARM64 的特色对指令，一条指令同时入栈/出栈 2 个寄存器，可自动增加 SP。</td>
									</tr>
									<tr>
										<td><strong>加法运算</strong></td>
										<td><code>add rax, rbx</code><br/>(<code>rax = rax + rbx</code>)</td>
										<td><code>add x0, x1, x2</code><br/>(<code>x0 = x1 + x2</code>)</td>
										<td>x86 为二地址制（覆写 dst）；ARM 为三地址制（保留 src1）。</td>
									</tr>
									<tr>
										<td><strong>减法运算</strong></td>
										<td><code>sub rax, 10</code></td>
										<td><code>sub x0, x1, #10</code></td>
										<td>自减操作。ARM 支持将常数限制在 12 位之内。</td>
									</tr>
									<tr>
										<td><strong>地址估算</strong></td>
										<td><code>lea rax, [rbx + rcx*4]</code></td>
										<td>不支持 (用多条 <code>add</code>/<code>lsl</code>)</td>
										<td>x86 特有的估算指令，常被巧妙当成 <code>y = a + b * c</code> 快速算术乘加器。</td>
									</tr>
									<tr>
										<td><strong>位逻辑与 / 或</strong></td>
										<td><code>and rax, rbx</code><br/><code>or rax, rbx</code></td>
										<td><code>and x0, x1, x2</code><br/><code>orr x0, x1, x2</code></td>
										<td>对两个寄存器按二进制位进行 AND / OR 操作。</td>
									</tr>
									<tr>
										<td><strong>逻辑左移 / 右移</strong></td>
										<td><code>shl rax, 2</code><br/><code>shr rax, 2</code></td>
										<td><code>lsl x0, x1, #2</code><br/><code>lsr x0, x1, #2</code></td>
										<td>左移等效于乘 2 的幂；逻辑右移补零。</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

					<!-- 子 Tab 3: 分支与控制指令 -->
					<div id="arch-inst-control" class="tab-panel">
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>跳转类型</th>
										<th>x86_64 指令</th>
										<th>ARM64 指令</th>
										<th>功能与标志位说明</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td><strong>无条件跳转</strong></td>
										<td><code>jmp label</code></td>
										<td><code>b label</code></td>
										<td>直接跳转到指定的标号。</td>
									</tr>
									<tr>
										<td><strong>条件比较</strong></td>
										<td><code>cmp rax, rbx</code></td>
										<td><code>cmp x0, x1</code></td>
										<td>比较两值并根据差值更新状态标志寄存器（EFLAGS / NZCV）。</td>
									</tr>
									<tr>
										<td><strong>等于跳转</strong></td>
										<td><code>je label</code></td>
										<td><code>b.eq label</code></td>
										<td>若比较结果相等（ZF = 1 / Z = 1），则执行跳转。</td>
									</tr>
									<tr>
										<td><strong>不等于跳转</strong></td>
										<td><code>jne label</code></td>
										<td><code>b.ne label</code></td>
										<td>若比较结果不相等（ZF = 0 / Z = 0），则执行跳转。</td>
									</tr>
									<tr>
										<td><strong>大于 / 小于跳转</strong></td>
										<td><code>jg label</code> (有符号)<br/><code>jl label</code> (有符号)</td>
										<td><code>b.gt label</code> (有符号)<br/><code>b.lt label</code> (有符号)</td>
										<td>根据有符号数大小状态执行跳转。</td>
									</tr>
									<tr>
										<td><strong>为零条件跳转</strong></td>
										<td>先 <code>test rax, rax</code><br/>再 <code>jz label</code></td>
										<td><code>cbz x0, label</code></td>
										<td>ARM 特色优化指令：直接检测寄存器是否为 0，跳过 CMP 标志位环节。</td>
									</tr>
									<tr>
										<td><strong>不为零条件跳转</strong></td>
										<td>先 <code>test rax, rax</code><br/>再 <code>jnz label</code></td>
										<td><code>cbnz x0, label</code></td>
										<td>直接检测寄存器非 0 并跳转。</td>
									</tr>
									<tr>
										<td><strong>子函数调用</strong></td>
										<td><code>call func</code></td>
										<td><code>bl func</code></td>
										<td>x86 压入返回地址入栈；ARM64 将返回地址存入 <code>x30(lr)</code>。</td>
									</tr>
									<tr>
										<td><strong>函数返回</strong></td>
										<td><code>ret</code></td>
										<td><code>ret</code></td>
										<td>x86 从栈顶弹出返回地址；ARM64 直接跳转到 <code>x30(lr)</code> 所指地址。</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

				</div>
			</section>

			<!-- 工具 C: 显卡 AI 算力与兼容性对照 -->
			<section id="tool-gpu-ai-perf" class="tool-section">
				<div class="glass-card">
					<div class="tool-header">
						<h2>⚡ 显卡 AI 算力与兼容性对照</h2>
						<p class="tool-desc">基于 SQLite 提取的 99 款显卡数据，提供单精度浮点（FP32）、AI 核心算力、显存带宽以及各类低精度数据格式（FP16/BF16/FP8/FP4/INT8/INT4）的兼容性矩阵，支持最多 3 款显卡同屏对比与算力性价比换算。</p>
					</div>

					<!-- 控制面板：搜索 + 多维度过滤 -->
					<div class="control-panel-gpu">
						<div class="filter-row-gpu">
							<div class="filter-group-gpu flex-grow">
								<label for="gpu-search">型号/架构检索</label>
								<input type="text" id="gpu-search" class="form-control-gpu" placeholder="输入型号或微架构关键字，如 4090, RDNA 3, Xe-HPG..." />
							</div>
							<div class="filter-group-gpu">
								<label for="gpu-vendor">品牌</label>
								<select id="gpu-vendor" class="form-control-gpu">
									<option value="">全部厂商</option>
									{vendors.map(v => <option value={v}>{v}</option>)}
								</select>
							</div>
							<div class="filter-group-gpu">
								<label for="gpu-arch">微架构</label>
								<select id="gpu-arch" class="form-control-gpu">
									<option value="">全部架构</option>
									{allArchitectures.map(a => <option value={a}>{a}</option>)}
								</select>
							</div>
							<div class="filter-group-gpu">
								<label for="gpu-segment">定位</label>
								<select id="gpu-segment" class="form-control-gpu">
									<option value="">全部定位</option>
									{allSegments.map(s => <option value={s}>{s}</option>)}
								</select>
							</div>
						</div>
					</div>

					<!-- 兼容性含义图例 -->
					<div class="legend-panel">
						<span class="legend-title">图例说明：</span>
						<span class="legend-item"><span class="capsule badge-all">FP16</span> 全支持 (CUDA + Tensor)</span>
						<span class="legend-item"><span class="capsule badge-cuda">FP16</span> 仅 CUDA Core</span>
						<span class="legend-item"><span class="capsule badge-tensor">FP16</span> 仅 Tensor Core</span>
						<span class="legend-item"><span class="capsule badge-none">FP16</span> 均不支持</span>
						<span class="legend-item"><span class="capsule badge-unknown">FP16</span> 支持未知</span>
					</div>

					<!-- 数据表格区域 -->
					<div class="table-wrapper">
						<table id="gpu-table">
							<thead>
								<tr>
									<th style="width: 60px; text-align: center;">对比</th>
									<th data-sort="model" class="sortable">型号 <span class="sort-icon">↕</span></th>
									<th data-sort="vendor" class="sortable">品牌 <span class="sort-icon">↕</span></th>
									<th data-sort="vram_gb" class="sortable text-right">显存 (GB) <span class="sort-icon">↕</span></th>
									<th data-sort="bandwidth_gbs" class="sortable text-right">带宽 (GB/s) <span class="sort-icon">↕</span></th>
									<th data-sort="fp32_tflops" class="sortable text-right">FP32 (TFLOPS) <span class="sort-icon">↕</span></th>
									<th data-sort="ai_core_perf" class="sortable text-right">AI 核心算力 <span class="sort-icon">↕</span></th>
									<th data-sort="power_w" class="sortable text-right">功耗 (W) <span class="sort-icon">↕</span></th>
									<th style="text-align: center;">格式兼容矩阵 (FP16 / BF16 / FP8 / FP4 / INT8 / INT4)</th>
								</tr>
							</thead>
							<tbody id="gpu-table-body">
								<!-- JS 动态填入 -->
							</tbody>
						</table>
					</div>
					
					<!-- 空状态提示 -->
					<div id="gpu-empty-state" class="empty-state" style="display: none;">
						<p>🔍 没有找到匹配的显卡数据，请尝试调整筛选条件。</p>
					</div>
				</div>
			</section>
		</main>
	</div>

	<!-- 底部悬浮对比面板 -->
	<div id="gpu-compare-bar" class="gpu-compare-bar">
		<div class="compare-container">
			<div class="compare-header">
				<div class="compare-header-left">
					<h3>⚖️ 显卡 AI 算力同屏对比</h3>
					<span class="compare-tip">最多支持对比 3 款显卡，可输入折合市价计算性价比指标</span>
				</div>
				<button id="compare-clear-btn" class="compare-clear-btn">清空对比</button>
			</div>
			<div id="compare-slots" class="compare-slots">
				<!-- JS 动态填入 -->
			</div>
		</div>
	</div>

	<!-- 注入编译期的静态 GPU 数据字典至前端全局变量 -->
	<script define:vars={{ gpuData }}>
		window.__GPU_DATA__ = gpuData;
	</script>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		// ==========================================
		// 1. 侧边栏工具切换交互
		// ==========================================
		const navItems = document.querySelectorAll('.nav-item');
		const toolSections = document.querySelectorAll('.tool-section');

		navItems.forEach(item => {
			item.addEventListener('click', () => {
				// 清除导航激活状态
				navItems.forEach(nav => nav.classList.remove('active'));
				// 设置当前激活
				item.classList.add('active');

				const activeTool = item.getAttribute('data-tool');

				// 切换对应的内容卡片
				toolSections.forEach(section => {
					if (section.id === `tool-${activeTool}`) {
						section.classList.add('active');
					} else {
						section.classList.remove('active');
					}
				});
			});
		});

		// ==========================================
		// 2. DDR 带宽计算器实时逻辑
		// ==========================================
		const ddrPreset = document.getElementById('ddr-preset');
		const ddrRate = document.getElementById('ddr-rate');
		const ddrWidth = document.getElementById('ddr-width');
		const ddrChannels = document.getElementById('ddr-channels');

		const bandwidthGbEl = document.getElementById('bandwidth-gb');
		const bandwidthMbEl = document.getElementById('bandwidth-mb');
		const totalWidthEl = document.getElementById('total-width');
		const clockFreqEl = document.getElementById('clock-freq');
		const calcFormulaEl = document.getElementById('calc-formula');

		// 核心计算并刷新回显函数
		function calculateBandwidth() {
			const rate = parseFloat(ddrRate.value) || 0;
			const width = parseInt(ddrWidth.value) || 0;
			const channels = parseInt(ddrChannels.value) || 0;

			// 带宽 (GB/s) = (速率 * 位宽 * 通道数) / 8 / 1000
			const bandwidthGb = (rate * width * channels) / 8 / 1000;
			const bandwidthMb = bandwidthGb * 1000;

			// 总位宽
			const totalWidth = width * channels;

			// 时钟频率 (等效双倍时钟速率核心频率为等效数据速率的一半)
			// 特殊说明：GDDR6 也是等效 2 倍物理频率，HBM/DDR 相同，为简化显示，以双倍率换算
			const clockFreq = rate / 2;

			// 回显结果
			bandwidthGbEl.textContent = bandwidthGb.toFixed(2);
			bandwidthMbEl.textContent = bandwidthMb.toLocaleString(undefined, { maximumFractionDigits: 0 }) + ' MB/s';
			totalWidthEl.textContent = `${totalWidth}-bit`;
			clockFreqEl.textContent = `${clockFreq.toFixed(1)} MHz`;

			// 公式更新
			calcFormulaEl.textContent = `带宽 = ${rate} MT/s × ${width}-bit × ${channels} 通道 ÷ 8 bits/Byte ÷ 1000 = ${bandwidthGb.toFixed(2)} GB/s`;

			// 动效：计算结果小缩放强调
			bandwidthGbEl.classList.add('pulse');
			setTimeout(() => bandwidthGbEl.classList.remove('pulse'), 200);
		}

		// 监听预设改变
		ddrPreset.addEventListener('change', () => {
			const selectedOption = ddrPreset.options[ddrPreset.selectedIndex];
			if (!selectedOption || !selectedOption.value) return;

			ddrRate.value = selectedOption.getAttribute('data-rate');
			ddrWidth.value = selectedOption.getAttribute('data-width');
			ddrChannels.value = selectedOption.getAttribute('data-channels');

			calculateBandwidth();
		});

		// 监听输入改动
		[ddrRate, ddrWidth, ddrChannels].forEach(el => {
			el.addEventListener('input', () => {
				// 若手动修改了任何输入，清空预设选项的高亮，设为自定义
				ddrPreset.value = "";
				calculateBandwidth();
			});
		});

		// 初始化计算
		calculateBandwidth();

		// ==========================================
		// 3. 汇编 Cheatsheet 子标签页切换交互
		// ==========================================
		const tabBtns = document.querySelectorAll('.tab-btn');
		const tabPanels = document.querySelectorAll('.tab-panel');

		tabBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				tabBtns.forEach(t => t.classList.remove('active'));
				btn.classList.add('active');

				const activeArch = btn.getAttribute('data-arch');

				tabPanels.forEach(panel => {
					if (panel.id === `arch-${activeArch}`) {
						panel.classList.add('active');
					} else {
						panel.classList.remove('active');
					}
				});
			});
		});

		// ==========================================
		// 4. 显卡 AI 算力与兼容性对照逻辑
		// ==========================================
		const gpus = window.__GPU_DATA__ || [];
		if (gpus.length > 0) {
			let searchVal = '';
			let selectedVendor = '';
			let selectedArch = '';
			let selectedSegment = '';
			
			let sortField = 'id';
			let sortOrder = 'asc';
			
			const selectedCompareIds = new Set();
			const priceMap = new Map();
			
			const searchInput = document.getElementById('gpu-search');
			const vendorSelect = document.getElementById('gpu-vendor');
			const archSelect = document.getElementById('gpu-arch');
			const segmentSelect = document.getElementById('gpu-segment');
			const tableBody = document.getElementById('gpu-table-body');
			const emptyState = document.getElementById('gpu-empty-state');
			
			const compareBar = document.getElementById('gpu-compare-bar');
			const compareSlots = document.getElementById('compare-slots');
			const compareClearBtn = document.getElementById('compare-clear-btn');
			
			// 胶囊格式化（包含各数据格式 5 种兼容状态气泡释义）
			function renderCapsules(item) {
				const formats = [
					{ name: 'FP16', val: item.fp16, desc: 'FP16 半精度浮点' },
					{ name: 'BF16', val: item.bf16, desc: 'BF16 混合精度浮点' },
					{ name: 'FP8', val: item.fp8, desc: 'FP8 低精度浮点' },
					{ name: 'FP4', val: item.fp4, desc: 'FP4 极低精度浮点' },
					{ name: 'INT8', val: item.int8, desc: 'INT8 整型数据' },
					{ name: 'INT4', val: item.int4, desc: 'INT4 低比特整型' }
				];

				return formats.map(f => {
					let statusClass = 'badge-unknown';
					let tooltipText = `${f.desc}: `;
					switch (f.val) {
						case '*':
							statusClass = 'badge-all';
							tooltipText += 'CUDA Core 与 Tensor Core 均支持 (全兼容)';
							break;
						case '+':
							statusClass = 'badge-cuda';
							tooltipText += '仅 CUDA Core 支持，Tensor Core 不支持';
							break;
						case '=':
							statusClass = 'badge-tensor';
							tooltipText += '仅 Tensor Core 支持，CUDA Core 不支持';
							break;
						case '-':
							statusClass = 'badge-none';
							tooltipText += '均不支持';
							break;
						case '?':
							statusClass = 'badge-unknown';
							tooltipText += '支持情况未知';
							break;
						default:
							statusClass = 'badge-unknown';
							tooltipText += f.val || '支持情况未知';
					}

					return `<span class="capsule-gpu ${statusClass}" title="${tooltipText}">${f.name}</span>`;
				}).join(' ');
			}
			
			// 渲染表格
			function renderTable() {
				let filtered = gpus.filter(item => {
					const sText = searchVal.toLowerCase();
					const matchesSearch = !sText || 
					                      item.model.toLowerCase().includes(sText) ||
					                      item.architecture.toLowerCase().includes(sText);
					const matchesVendor = !selectedVendor || item.vendor === selectedVendor;
					const matchesArch = !selectedArch || item.architecture === selectedArch;
					const matchesSegment = !selectedSegment || item.segment === selectedSegment;
					
					return matchesSearch && matchesVendor && matchesArch && matchesSegment;
				});
				
				// 排序
				filtered.sort((a, b) => {
					let valA = a[sortField];
					let valB = b[sortField];
					
					if (valA === null || valA === undefined) return sortOrder === 'asc' ? 1 : -1;
					if (valB === null || valB === undefined) return sortOrder === 'asc' ? -1 : 1;
					
					if (typeof valA === 'string') {
						return sortOrder === 'asc' 
							? valA.localeCompare(valB)
							: valB.localeCompare(valA);
					} else {
						return sortOrder === 'asc' ? valA - valB : valB - valA;
					}
				});
				
				if (filtered.length === 0) {
					tableBody.innerHTML = '';
					emptyState.style.display = 'block';
					return;
				}
				
				emptyState.style.display = 'none';
				
				tableBody.innerHTML = filtered.map(item => {
					const isChecked = selectedCompareIds.has(item.id) ? 'checked' : '';
					const aiCoreText = item.ai_core_perf 
						? `${item.ai_core_perf} <span class="unit-sub-gpu">${item.ai_core_unit || 'TFLOPS'}</span>`
						: '<span class="none-sub-gpu">-</span>';
						
					return `
						<tr>
							<td style="text-align: center;">
								<input type="checkbox" class="gpu-compare-cb" data-id="${item.id}" ${isChecked} />
							</td>
							<td class="font-semibold-gpu">${item.model}</td>
							<td><span class="vendor-tag-gpu tag-gpu-${item.vendor.toLowerCase()}">${item.vendor}</span></td>
							<td class="text-right">${item.vram_gb !== null ? item.vram_gb : '-'}</td>
							<td class="text-right">${item.bandwidth_gbs !== null ? item.bandwidth_gbs : '-'}</td>
							<td class="text-right">${item.fp32_tflops !== null ? item.fp32_tflops : '-'}</td>
							<td class="text-right">${aiCoreText}</td>
							<td class="text-right">${item.power_w !== null ? item.power_w : '-'}</td>
							<td style="text-align: center;">
								<div class="capsules-flex-gpu">${renderCapsules(item)}</div>
							</td>
						</tr>
					`;
				}).join('');
				
				bindCheckboxEvents();
			}
			
			// 绑定复选框事件
			function bindCheckboxEvents() {
				const cbs = tableBody.querySelectorAll('.gpu-compare-cb');
				cbs.forEach(cb => {
					cb.addEventListener('change', () => {
						const id = parseInt(cb.getAttribute('data-id'));
						if (cb.checked) {
							if (selectedCompareIds.size >= 3) {
								alert('最多支持同时对比 3 款显卡！');
								cb.checked = false;
								return;
							}
							selectedCompareIds.add(id);
						} else {
							selectedCompareIds.delete(id);
						}
						renderComparePanel();
					});
				});
			}
			
			// 渲染对比面板
			function renderComparePanel() {
				if (selectedCompareIds.size === 0) {
					compareBar.classList.remove('active');
					return;
				}
				
				compareBar.classList.add('active');
				
				const selectedItems = gpus.filter(item => selectedCompareIds.has(item.id));
				
				// 计算最大值基准
				const maxVram = Math.max(...selectedItems.map(i => i.vram_gb || 0), 1);
				const maxBandwidth = Math.max(...selectedItems.map(i => i.bandwidth_gbs || 0), 1);
				const maxFp32 = Math.max(...selectedItems.map(i => i.fp32_tflops || 0), 1);
				const maxAiCore = Math.max(...selectedItems.map(i => i.ai_core_perf || 0), 1);
				const maxPower = Math.max(...selectedItems.map(i => i.power_w || 0), 1);
				
				compareSlots.innerHTML = selectedItems.map(item => {
					const price = priceMap.get(item.id) || '';
					
					const pctVram = ((item.vram_gb || 0) / maxVram) * 100;
					const pctBandwidth = ((item.bandwidth_gbs || 0) / maxBandwidth) * 100;
					const pctFp32 = ((item.fp32_tflops || 0) / maxFp32) * 100;
					const pctAiCore = ((item.ai_core_perf || 0) / maxAiCore) * 100;
					const pctPower = ((item.power_w || 0) / maxPower) * 100;
					
					let costPerFp32 = '-';
					let costPerVram = '-';
					let costPerAi = '-';
					
					if (price) {
						const pVal = parseFloat(price);
						if (pVal > 0) {
							if (item.fp32_tflops) costPerFp32 = (pVal / item.fp32_tflops).toFixed(1) + ' 元/TFLOPS';
							if (item.vram_gb) costPerVram = (pVal / item.vram_gb).toFixed(1) + ' 元/GB';
							if (item.ai_core_perf) costPerAi = (pVal / item.ai_core_perf).toFixed(1) + ' 元/' + (item.ai_core_unit || 'TFLOPS');
						}
					}
					
					return `
						<div class="compare-card-gpu glass-card-sub-gpu" data-card-id="${item.id}">
							<div class="card-gpu-title">
								<h4>${item.model}</h4>
								<span class="vendor-tag-gpu tag-gpu-${item.vendor.toLowerCase()}">${item.vendor}</span>
							</div>
							
							<div class="compare-metrics">
								<div class="metric-row">
									<div class="metric-lbl">显存容量: <span>${item.vram_gb || '-'} GB</span></div>
									<div class="progress-bar-container-gpu">
										<div class="progress-bar-gpu bar-vram-gpu" style="width: ${pctVram}%;"></div>
									</div>
								</div>
								<div class="metric-row">
									<div class="metric-lbl">显存带宽: <span>${item.bandwidth_gbs || '-'} GB/s</span></div>
									<div class="progress-bar-container-gpu">
										<div class="progress-bar-gpu bar-width-gpu" style="width: ${pctBandwidth}%;"></div>
									</div>
								</div>
								<div class="metric-row">
									<div class="metric-lbl">FP32 算力: <span>${item.fp32_tflops || '-'} TFLOPS</span></div>
									<div class="progress-bar-container-gpu">
										<div class="progress-bar-gpu bar-fp32-gpu" style="width: ${pctFp32}%;"></div>
									</div>
								</div>
								<div class="metric-row">
									<div class="metric-lbl">AI 核心算力: <span>${item.ai_core_perf ? (item.ai_core_perf + ' ' + (item.ai_core_unit || 'TFLOPS')) : '-'}</span></div>
									<div class="progress-bar-container-gpu">
										<div class="progress-bar-gpu bar-ai-gpu" style="width: ${pctAiCore}%;"></div>
									</div>
								</div>
								<div class="metric-row">
									<div class="metric-lbl">设计功耗: <span>${item.power_w || '-'} W</span></div>
									<div class="progress-bar-container-gpu">
										<div class="progress-bar-gpu bar-power-gpu" style="width: ${pctPower}%;"></div>
									</div>
								</div>
							</div>
							
							<div class="compare-pricing">
								<div class="price-input-group">
									<label>预估价格 (元)</label>
									<input type="number" class="compare-price-input" data-id="${item.id}" value="${price}" placeholder="输入预估价格" />
								</div>
								<div class="price-results">
									<div><small>单精度性价比：</small><span>${costPerFp32}</span></div>
									<div><small>显存容量性价比：</small><span>${costPerVram}</span></div>
									<div><small>AI 算力性价比：</small><span>${costPerAi}</span></div>
								</div>
							</div>
						</div>
					`;
				}).join('');
				
				bindPriceInputEvents();
			}
			
			// 绑定价格输入事件（防丢失焦点和数据局域更新）
			function bindPriceInputEvents() {
				const inputs = compareSlots.querySelectorAll('.compare-price-input');
				inputs.forEach(input => {
					input.addEventListener('input', () => {
						const id = parseInt(input.getAttribute('data-id'));
						priceMap.set(id, input.value);
						
						const pVal = parseFloat(input.value);
						const item = gpus.find(i => i.id === id);
						if (item) {
							let costPerFp32 = '-';
							let costPerVram = '-';
							let costPerAi = '-';
							
							if (pVal > 0) {
								if (item.fp32_tflops) costPerFp32 = (pVal / item.fp32_tflops).toFixed(1) + ' 元/TFLOPS';
								if (item.vram_gb) costPerVram = (pVal / item.vram_gb).toFixed(1) + ' 元/GB';
								if (item.ai_core_perf) costPerAi = (pVal / item.ai_core_perf).toFixed(1) + ' 元/' + (item.ai_core_unit || 'TFLOPS');
							}
							
							const card = compareSlots.querySelector(`.compare-card-gpu[data-card-id="${id}"]`);
							if (card) {
								const spans = card.querySelectorAll('.price-results span');
								if (spans.length >= 3) {
									spans[0].textContent = costPerFp32;
									spans[1].textContent = costPerVram;
									spans[2].textContent = costPerAi;
								}
							}
						}
					});
				});
			}
			
			// 清空对比
			compareClearBtn.addEventListener('click', () => {
				selectedCompareIds.clear();
				priceMap.clear();
				renderTable();
				renderComparePanel();
			});
			
			// 排序头绑定
			const headers = document.querySelectorAll('#gpu-table th.sortable');
			headers.forEach(header => {
				header.addEventListener('click', () => {
					const field = header.getAttribute('data-sort');
					if (sortField === field) {
						sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
					} else {
						sortField = field;
						sortOrder = 'desc';
					}
					
					headers.forEach(h => {
						const icon = h.querySelector('.sort-icon');
						if (h === header) {
							icon.textContent = sortOrder === 'asc' ? '↑' : '↓';
							h.classList.add('sorted');
						} else {
							icon.textContent = '↕';
							h.classList.remove('sorted');
						}
					});
					
					renderTable();
				});
			});
			
			// 筛选事件绑定
			searchInput.addEventListener('input', (e) => {
				searchVal = e.target.value;
				renderTable();
			});
			
			vendorSelect.addEventListener('change', (e) => {
				selectedVendor = e.target.value;
				renderTable();
			});
			
			archSelect.addEventListener('change', (e) => {
				selectedArch = e.target.value;
				renderTable();
			});
			
			segmentSelect.addEventListener('change', (e) => {
				selectedSegment = e.target.value;
				renderTable();
			});
			
			// 专门为工具箱内显卡表格挂载多向粘性表头垂直滚动联动逻辑
			const navbar = document.querySelector('header');
			const tableWrapper = document.querySelector('#tool-gpu-ai-perf .table-wrapper');
			
			const handleStickyScroll = () => {
				if (!tableWrapper) return;
				const navbarHeight = navbar ? navbar.offsetHeight : 56;
				const table = tableWrapper.querySelector('table');
				const thead = tableWrapper.querySelector('thead');
				if (!table || !thead) return;
				
				const wrapperRect = tableWrapper.getBoundingClientRect();
				const theadHeight = thead.offsetHeight;
				
				let offsetY = 0;
				if (wrapperRect.top < navbarHeight) {
					const maxOffset = wrapperRect.height - theadHeight;
					offsetY = Math.min(navbarHeight - wrapperRect.top, maxOffset);
				}
				
				const ths = thead.querySelectorAll('th');
				ths.forEach(th => {
					th.style.transform = `translateY(${offsetY}px)`;
				});
			};
			
			window.addEventListener('scroll', handleStickyScroll, { passive: true });
			window.addEventListener('resize', handleStickyScroll, { passive: true });
			
			// 初始化载入
			renderTable();
		}
	});
</script>

<style>
	/* 布局网格 */
	.tools-layout {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: 1.5rem;
		max-width: var(--content-width);
		margin: 2rem auto;
		padding: 0 1rem;
		align-items: start;
	}

	/* 侧边栏 */
	.tools-sidebar {
		position: sticky;
		top: 5rem;
