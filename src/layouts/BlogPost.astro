---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import PostNavigation from '../components/PostNavigation.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { encodeHrefSegment, type PostNeighbors, type TocHeading } from '../lib/blog';
import BaseLayout from './BaseLayout.astro';
import { GISCUS_CONFIG } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	tocItems?: TocHeading[];
	previous?: PostNeighbors['previous'];
	next?: PostNeighbors['next'];
	wordCount?: number;
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	categories,
	tags,
	tocItems = [],
	previous = null,
	next = null,
	wordCount = 0,
	readingTime = 0,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="post-shell">
		<article class="post">
			<header class="post-header">
				<p class="post-date">
					发布于 <FormattedDate date={pubDate} />
					{
						updatedDate && (
							<>
								<span aria-hidden="true"> · </span>
								更新于 <FormattedDate date={updatedDate} />
							</>
						)
					}
					{
						wordCount > 0 && (
							<>
								<span aria-hidden="true"> · </span>
								<span>约 {wordCount} 字</span>
							</>
						)
					}
					{
						readingTime > 0 && (
							<>
								<span aria-hidden="true"> · </span>
								<span>预计阅读 {readingTime} 分钟</span>
							</>
						)
					}
					<span aria-hidden="true"> · </span>
					<span id="busuanzi_container_page_pv" style="display: none;">
						阅读量 <span id="busuanzi_value_page_pv"></span> 次
					</span>
				</p>
				<h1>{title}</h1>
				{
					(categories.length > 0 || tags.length > 0) && (
						<div class="post-taxonomy">
							{categories.map((category) => (
								<a href={`/categories/${encodeHrefSegment(category)}/`}>{category}</a>
							))}
							{tags.map((tag) => (
								<a href={`/tags/${encodeHrefSegment(tag)}/`}>#{tag}</a>
							))}
						</div>
					)
				}
			</header>
			<TableOfContents items={tocItems} />
			<div class="prose">
				<slot />
			</div>
			<PostNavigation previous={previous} next={next} />
			<!-- Giscus 评论区容器 -->
			<div class="post-comments">
				<div 
					class="giscus"
					data-repo={GISCUS_CONFIG.repo}
					data-repo-id={GISCUS_CONFIG.repoId}
					data-category={GISCUS_CONFIG.category}
					data-category-id={GISCUS_CONFIG.categoryId}
					data-mapping={GISCUS_CONFIG.mapping}
					data-strict={GISCUS_CONFIG.strict}
					data-reactions-enabled={GISCUS_CONFIG.reactionsEnabled}
					data-emit-metadata={GISCUS_CONFIG.emitMetadata}
					data-input-position={GISCUS_CONFIG.inputPosition}
					data-theme="transparent_dark"
					data-lang={GISCUS_CONFIG.lang}
					data-loading={GISCUS_CONFIG.loading}
					crossorigin="anonymous"
				></div>
			</div>
		</article>
		<TableOfContents items={tocItems} />
	</div>
	<script is:inline>
		const parseCodeMeta = (source) => {
			const value = source.trim();
			const firstToken = value.match(/^[^\s]+/)?.[0] ?? null;
			const titleMatch = value.match(/(?:^|\s)title=(?:"([^"]*)"|'([^']*)'|([^\s]+))/);
			const language = firstToken && !firstToken.includes('=') && !firstToken.startsWith('{') ? firstToken : null;
			const title = titleMatch?.[1] ?? titleMatch?.[2] ?? titleMatch?.[3] ?? null;

			return {
				language,
				label: title ?? language ?? 'code',
			};
		};

		document.querySelectorAll('[data-code-block-meta]').forEach((marker) => {
			const figure = marker.nextElementSibling;

			if (!(figure instanceof HTMLElement) || !figure.classList.contains('code-block')) {
				return;
			}

			const meta = parseCodeMeta(marker.getAttribute('data-code-block-meta') ?? '');
			const label = figure.querySelector('.code-block__label');
			const button = figure.querySelector('[data-code-copy]');

			figure.dataset.language = meta.language ?? 'code';

			if (label) {
				label.textContent = meta.label;
			}

			if (button) {
				button.setAttribute('aria-label', `复制 ${meta.label} 代码`);
			}

			marker.remove();
		});

		document.addEventListener('click', async (event) => {
			const target = event.target;

			if (!(target instanceof Element)) {
				return;
			}

			const button = target.closest('[data-code-copy]');

			if (!(button instanceof HTMLElement)) {
				return;
			}

			const text = button.getAttribute('data-code-text') ?? '';
			const original = button.textContent;

			try {
				await navigator.clipboard.writeText(text);
				button.textContent = '已复制';
				window.setTimeout(() => {
					button.textContent = original;
				}, 1600);
			} catch {
				button.textContent = '复制失败';
				window.setTimeout(() => {
					button.textContent = original;
				}, 1600);
			}
		});

		// TOC (目录) 视口动态追踪高亮
		(function () {
			const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
			const tocLinks = Array.from(document.querySelectorAll('.toc a'));
			
			if (headings.length === 0 || tocLinks.length === 0) {
				return;
			}
			
			const activeClass = 'active';
			const visibleHeadingsMap = new Map();
			
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					visibleHeadingsMap.set(entry.target, entry.isIntersecting);
				});
				
				let activeHeading = null;
				for (const heading of headings) {
					if (visibleHeadingsMap.get(heading)) {
						activeHeading = heading;
						break;
					}
				}
				
				if (!activeHeading) {
					const scrollY = window.scrollY || window.pageYOffset;
					for (let i = headings.length - 1; i >= 0; i--) {
						const rect = headings[i].getBoundingClientRect();
						const top = rect.top + scrollY;
						if (scrollY >= top - 200) {
							activeHeading = headings[i];
							break;
						}
					}
				}
				
				if (!activeHeading && headings.length > 0) {
					activeHeading = headings[0];
				}
				
				if (activeHeading) {
					const activeId = activeHeading.getAttribute('id');
					tocLinks.forEach((link) => {
						const href = link.getAttribute('href');
						if (href === `#${activeId}`) {
							link.classList.add(activeClass);
						} else {
							link.classList.remove(activeClass);
						}
					});
				}
			}, {
				rootMargin: '-80px 0px -40% 0px',
				threshold: 0
			});
			
			headings.forEach(heading => observer.observe(heading));
		})();

		// Giscus 异步加载与主题联动同步器
		(function() {
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			};
			
			const giscusTheme = getTheme() === 'dark' ? 'transparent_dark' : 'light';
			const giscusEl = document.querySelector('.giscus');
			if (giscusEl) {
				giscusEl.setAttribute('data-theme', giscusTheme);
			}
			
			// 创建 giscus 脚本并挂载
			const script = document.createElement('script');
			script.src = 'https://giscus.app/client.js';
			script.setAttribute('data-repo', giscusEl?.getAttribute('data-repo') || '');
			script.setAttribute('data-repo-id', giscusEl?.getAttribute('data-repo-id') || '');
			script.setAttribute('data-category', giscusEl?.getAttribute('data-category') || '');
			script.setAttribute('data-category-id', giscusEl?.getAttribute('data-category-id') || '');
			script.setAttribute('data-mapping', giscusEl?.getAttribute('data-mapping') || '');
			script.setAttribute('data-strict', giscusEl?.getAttribute('data-strict') || '0');
			script.setAttribute('data-reactions-enabled', giscusEl?.getAttribute('data-reactions-enabled') || '1');
			script.setAttribute('data-emit-metadata', giscusEl?.getAttribute('data-emit-metadata') || '0');
			script.setAttribute('data-input-position', giscusEl?.getAttribute('data-input-position') || 'top');
			script.setAttribute('data-theme', giscusTheme);
			script.setAttribute('data-lang', giscusEl?.getAttribute('data-lang') || 'zh-CN');
			script.setAttribute('data-loading', giscusEl?.getAttribute('data-loading') || 'lazy');
			script.crossOrigin = 'anonymous';
			script.async = true;
			
			document.head.appendChild(script);
			
			// 动态监听全局 class 变化，通知 giscus iframe 同步切换主题
			const updateGiscusTheme = () => {
				const currentTheme = document.documentElement.classList.contains('dark') ? 'transparent_dark' : 'light';
				const iframe = document.querySelector('iframe.giscus-frame');
				if (iframe && iframe.contentWindow) {
					iframe.contentWindow.postMessage(
						{ giscus: { setConfig: { theme: currentTheme } } },
						'https://giscus.app'
					);
				}
			};
			
			const observer = new MutationObserver((mutations) => {
				mutations.forEach((mutation) => {
					if (mutation.attributeName === 'class') {
						updateGiscusTheme();
					}
				});
			});
			
			observer.observe(document.documentElement, { attributes: true });
		})();

		// ==========================================
		// 动态控制表格在垂直滚动时的多向粘性定位 (解决 overflow-x: auto 与 position: sticky 冲突问题)
		// ==========================================
		(function () {
			const navbar = document.querySelector('header');
			const tableWrappers = document.querySelectorAll('.table-wrapper');
			
			if (tableWrappers.length === 0) return;
			
			const handleScroll = () => {
				// 获取 sticky 导航栏的高度作为粘滞基准 top 值
				const navbarHeight = navbar ? navbar.offsetHeight : 56;
				
				tableWrappers.forEach((wrapper) => {
					const table = wrapper.querySelector('table');
					const thead = wrapper.querySelector('thead');
					if (!table || !thead) return;
					
					const wrapperRect = wrapper.getBoundingClientRect();
					const theadHeight = thead.offsetHeight;
					
					// 仅当表格顶部滑入导航栏下方，且表格仍未完全滚出视口时，才对表头进行垂直偏移
					let offsetY = 0;
					if (wrapperRect.top < navbarHeight) {
						const maxOffset = wrapperRect.height - theadHeight;
						offsetY = Math.min(navbarHeight - wrapperRect.top, maxOffset);
					}
					
					// 应用 transform 进行偏移（带 GPU 硬件加速，滚动流畅无卡顿）
					const ths = thead.querySelectorAll('th');
					ths.forEach((th) => {
						th.style.transform = `translateY(${offsetY}px)`;
					});
				});
			};
			
			// 绑定滚动和窗口拉伸事件，确保位置实时正确
			window.addEventListener('scroll', handleScroll, { passive: true });
			window.addEventListener('resize', handleScroll, { passive: true });
			
			// 触发一次初始化
			handleScroll();
		})();
	</script>
</BaseLayout>
